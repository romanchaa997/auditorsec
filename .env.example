# AuditorSEC Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# MinIO credentials
MINIO_ACCESS_KEY=auditorsec
MINIO_SECRET_KEY=changeme_min32chars_use_strong_password

# PostgreSQL (auto-configured via docker-compose)
# DATABASE_URL=postgresql://auditor:secret@db:5432/auditorsec

# Redis (auto-configured via docker-compose)
# REDIS_URL=redis://redis:6379/0
